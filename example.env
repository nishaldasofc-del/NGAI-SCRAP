# =============================================================================
# NGAI — Production Configuration Template
# =============================================================================

# --- Database & Persistence ---
# Note: In Railway/Render, these will be overridden by internal variables.
DATABASE_URL=postgresql+asyncpg://ngai:ngaisecret@localhost:5432/ngai
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ngai_minio
MINIO_SECRET_KEY=ngai_minio_secret
MINIO_BUCKET=ngai-raw

# --- LLM & AI Configuration ---
# OpenRouter API Key (Mandatory for Agent Intelligence)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pick any model slug from openrouter.ai/models
DEFAULT_LLM=google/gemini-flash-1.5

# --- Embeddings ---
# EMBEDDING_PROVIDER: "local" (no key) or "openai" (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local
# Only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-small

# --- Scraping & Performance ---
MAX_CONCURRENT_SCRAPERS=5
REQUEST_TIMEOUT=30
# Add proxies here if needed (e.g., http://user:pass@proxy-server:port)
PROXY_LIST=
USE_PLAYWRIGHT=True

# --- Security & Auth ---
# Comma-separated list for API access
API_KEYS=your_secret_api_key_1,your_secret_api_key_2
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# --- Cache ---
CACHE_TTL_SECONDS=300
